# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev): sqlite+aiosqlite:///./artisangps.db
# PostgreSQL (production): postgresql+asyncpg://user:password@host:5432/artisangps
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/artisangps

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-strong-random-secret-min-32-chars
JWT_EXPIRE_DAYS=7

# ── AI / LLM ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GROQ_API_KEY=gsk-your-groq-key-here

# ── Market Data ───────────────────────────────────────────────────────────────
# Alpha Vantage (free tier — 25 calls/day): https://alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# Upstox Developer API (MCX live prices — optional, for production)
# Register at https://upstox.com/developer
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_API_SECRET=your_upstox_api_secret_here
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true once you have real commodity data flowing
ENABLE_COMMODITY_PRICES=false
# Set to true once shared models are trained and serialized
ENABLE_SHARED_CRAFT_MODELS=false
